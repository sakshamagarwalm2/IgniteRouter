{
  "name": "igniterouter",
  "version": "0.1.0",
  "description": "Smart LLM router — route requests to the right model with automatic fallback",
  "type": "module",
  "main": "./dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "igniterouter": "./dist/cli.js"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "docs/*.md",
    "docs/*.png",
    "scripts",
    "skills",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:verify": "vitest run test/verify-all.test.ts --reporter=verbose",
    "test:verify:watch": "vitest test/verify-all.test.ts --reporter=verbose",
    "test:install": "bash test/openclaw-install.sh",
    "test:integration": "vitest run test/integration-flow.test.ts test/provider-urls.test.ts",
    "test:all": "vitest run && npm run test:install",
    "test:unit": "vitest run src/task-classifier.test.ts src/complexity-scorer.test.ts src/user-providers.test.ts src/routing-engine.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "llm",
    "router",
    "smart-routing",
    "ai",
    "openclaw"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": ">=2025.1.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "openclaw": "^2026.4.5",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
